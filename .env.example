# .env.example

# ── Docker Oracle 설정 ──────────────────
ORACLE_PASSWORD=your_oracle_password
APP_USER=your_db_user
APP_USER_PASSWORD=your_db_password

# ── SpringBoot DB 연결 설정 ─────────────
DB_URL=jdbc:oracle:thin:@localhost:1521/XEPDB1
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── 서버 설정 ───────────────────────────
SERVER_PORT=8080